<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ========================================================= -->
    <!-- Redirection automatique vers la page d'accueil VETES       -->
    <!-- ========================================================= -->
    <!--
        Ce fichier configure :
        - une action client "reload" permettant de forcer
          l'ouverture du menu et de l'action de la homepage.
        - une valeur par défaut (ir.default) appliquant cette action
          comme écran d'accueil pour tous les utilisateurs.
        Aucun impact métier : uniquement une configuration UI.
    -->

    <!-- Action client : recharge et redirige vers la homepage -->
    <record id="action_vetes_redirect_home" model="ir.actions.client">
        <field name="tag">reload</field>
        <field name="params">
            {
                "menu_id": ref("vetes_homepage_menu"),
                "action_id": ref("action_vetes_homepage")
            }
        </field>
    </record>

    <!-- Définition de l'action par défaut pour les utilisateurs -->
    <record id="vetes_default_home_action" model="ir.default">
        <field name="model_id" ref="base.model_res_users"/>
        <field name="field_id" ref="base.field_res_users__action_id"/>
        <field name="json_value">"action_vetes_redirect_home"</field>
    </record>

</odoo>
