<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ========================================================= -->
    <!-- FORMULAIRE AGENT (avec chatter)                          -->
    <!-- Objectif IT :                                             -->
    <!-- - Masquage RGPD du registre national                      -->
    <!-- - Affichage clair uniquement lors de la création          -->
    <!-- - Bouton œil = afficher/masquer (champ non stocké)        -->
    <!-- - show_registre doit être présent dans la vue             -->
    <!-- ========================================================= -->
    <record id="view_epi_agent_form" model="ir.ui.view">
        <field name="name">epi.agent.form</field>
        <field name="model">epi.agent</field>
        <field name="arch" type="xml">

            <form string="Agent">

                <header>
                    <button name="toggle_active"
                            type="object"
                            string="Archiver"
                            attrs="{'invisible': [('active','=',False)]}"
                            class="btn-secondary"/>

                    <button name="toggle_active"
                            type="object"
                            string="Reactivier"
                            attrs="{'invisible': [('active','=',True)]}"
                            class="btn-primary"/>

                    <field name="active" invisible="1"/>
                </header>

                <sheet>

                    <!-- Identité -->
                    <group string="Identité">
                        <group>

                            <field name="name" string="Nom"/>
                            <field name="firstname" string="Prénom"/>
                            <field name="matricule" string="Matricule"/>

                            <!-- Champ réel → visible uniquement lors de la création -->
                            <field name="registre_national"
                                   string="Registre national"
                                   attrs="{'invisible': [('id','!=',False)]}"/>

                            <!-- Champ masqué ou réel selon show_registre -->
                            <field name="registre_national_masked"
                                   string="Registre national"
                                   readonly="1"
                                   attrs="{'invisible': [('id','=',False)]}"/>

                            <!-- Champ interne nécessaire pour rafraîchir la vue -->
                            <field name="show_registre" invisible="1"/>

                            <!-- Bouton œil → toggle afficher/masquer -->
                            <button name="action_toggle_registre"
                                    type="object"
                                    icon="fa-eye"
                                    string="Afficher / Masquer"
                                    attrs="{'invisible': [('id','=',False)]}"/>

                        </group>

                        <group>
                            <field name="fonction" string="Fonction"/>
                            <field name="contrat" string="Contrat"/>
                            <field name="batiment_id" string="Bâtiment"/>
                            <field name="travail_en_hauteur" string="Travail en hauteur"/>
                        </group>
                    </group>

                    <!-- Contrat -->
                    <group string="Contrat">
                        <field name="date_fin_contrat" string="Fin de contrat"/>
                        <field name="is_expired" readonly="1" string="Expiré"/>
                    </group>

                    <!-- Remarques -->
                    <group string="Remarques">
                        <field name="remarque"/>
                    </group>

                    <!-- Onglets -->
                    <notebook>

                        <!-- Historique des mouvements -->
                        <page string="Historique des mouvements">
                            <field name="mouvement_ligne_ids">
                                <tree string="Historique des mouvements">
                                    <field name="date_mouvement" string="Date"/>
                                    <field name="type_mouvement" string="Type"/>
                                    <field name="article_id" string="Article"/>
                                    <field name="quantite" string="Quantité"/>
                                    <field name="remarque" string="Remarque"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Documents (chatter) -->
                        <page string="Documents">
                            <field name="message_ids" widget="mail_thread"/>
                        </page>

                    </notebook>

                </sheet>

                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>

        </field>
    </record>

    <!-- ========================================================= -->
    <!-- LISTE AGENTS                                              -->
    <!-- ========================================================= -->
    <record id="view_epi_agent_tree" model="ir.ui.view">
        <field name="name">epi.agent.tree</field>
        <field name="model">epi.agent</field>
        <field name="arch" type="xml">

            <tree string="Agents" decoration-danger="is_expired">

                <field name="is_expired" invisible="1"/>

                <field name="name" string="Nom"/>
                <field name="firstname" string="Prénom"/>
                <field name="matricule" string="Matricule"/>
                <field name="fonction" string="Fonction"/>
                <field name="contrat" string="Contrat"/>
                <field name="batiment_id" string="Bâtiment"/>
                <field name="date_fin_contrat" string="Fin de contrat"/>
                <field name="active" string="Actif"/>
            </tree>

        </field>
    </record>

    <!-- ========================================================= -->
    <!-- SEARCH VIEW AGENTS                                        -->
    <!-- ========================================================= -->
    <record id="view_epi_agent_search" model="ir.ui.view">
        <field name="name">epi.agent.search</field>
        <field name="model">epi.agent</field>
        <field name="arch" type="xml">

            <search string="Recherche agents">

                <field name="name" string="Nom"/>
                <field name="firstname" string="Prénom"/>
                <field name="matricule" string="Matricule"/>
                <field name="batiment_id" string="Bâtiment"/>

                <filter name="active_agents" string="Actifs"
                        domain="[('active','=',True)]"/>

                <filter name="expired_agents" string="Contrat expiré"
                        domain="[('is_expired','=',True)]"/>

                <filter name="archived_agents" string="Archivés"
                        domain="[('active','=',False)]"/>

                <filter name="all_agents" string="Tous" domain="[]"/>

                <group expand="0" string="Regrouper par">
                    <filter name="group_batiment"
                            string="Bâtiment"
                            context="{'group_by':'batiment_id'}"/>

                    <filter name="group_contrat"
                            string="Contrat"
                            context="{'group_by':'contrat'}"/>
                </group>

            </search>

        </field>
    </record>

    <!-- ========================================================= -->
    <!-- ACTION AGENTS                                             -->
    <!-- ========================================================= -->
    <record id="action_epi_agent" model="ir.actions.act_window">
        <field name="name">Agents</field>
        <field name="res_model">epi.agent</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_epi_agent_search"/>
    </record>

</odoo>
