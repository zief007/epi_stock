<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ========================================================= -->
    <!-- LISTE : Inventaires                                       -->
    <!-- Objectif IT :                                             -->
    <!-- - Décoration rouge si inventaire validé                   -->
    <!-- - Colonnes essentielles                                   -->
    <!-- ========================================================= -->
    <record id="view_inventory_tree" model="ir.ui.view">
        <field name="name">epi.inventory.tree</field>
        <field name="model">epi.inventory</field>
        <field name="arch" type="xml">

            <tree string="Inventaires"
                  decoration-danger="state == 'done'">

                <field name="name" string="Nom"/>
                <field name="date_inventory" string="Date de l'inventaire"/>
                <field name="category_id" string="Catégorie"/>
                <field name="state" string="État"/>
            </tree>

        </field>
    </record>

    <!-- ========================================================= -->
    <!-- FORMULAIRE : Inventaire                                   -->
    <!-- Objectif IT :                                             -->
    <!-- - Boutons métier (charger / valider / Excel)              -->
    <!-- - Lignes éditables tant que brouillon                     -->
    <!-- ========================================================= -->
    <record id="view_inventory_form" model="ir.ui.view">
        <field name="name">epi.inventory.form</field>
        <field name="model">epi.inventory</field>
        <field name="arch" type="xml">

            <form string="Inventaire">

                <header>
                    <button name="action_charger_articles"
                            string="Charger les articles"
                            type="object"
                            class="btn-primary"/>

                    <button name="action_valider"
                            string="Valider l'inventaire"
                            type="object"
                            states="draft"
                            class="btn-success"/>

                    <button name="action_export_excel"
                            string="Exporter Excel"
                            type="object"
                            class="btn-secondary"/>
                </header>

                <sheet>

                    <group string="Informations">
                        <field name="name" string="Nom"/>
                        <field name="date_inventory" string="Date de l'inventaire"/>
                        <field name="category_id" string="Catégorie"/>
                        <field name="state" readonly="1" string="État"/>
                    </group>

                    <notebook>

                        <!-- Lignes d’inventaire -->
                        <page string="Lignes d'inventaire">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="article_id" string="Article"/>
                                    <field name="stock_theorique" string="Stock théorique"/>
                                    <field name="stock_reel" string="Stock réel"/>
                                    <field name="ecart" string="Écart"/>
                                </tree>
                            </field>
                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>
    </record>

</odoo>
